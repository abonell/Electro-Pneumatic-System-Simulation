---
import { servicios } from '../data/servicios';
import { sectores } from '../data/sectores';
import { waUrl } from '../data/site';

interface Props {
  /** Pre-fill servicio dropdown with this slug if provided. */
  preselectedServicio?: string;
}

const { preselectedServicio } = Astro.props;
---

<section
  id="cotizacion"
  class="py-24 lg:py-32"
  aria-labelledby="cotizacion-heading"
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

    <header class="text-center max-w-2xl mx-auto mb-12 reveal">
      <p class="font-sub text-sm tracking-widest mb-3 section-eyebrow inline-flex text-blue-400">
        SOLICITAR COTIZACIÓN
      </p>
      <h2 id="cotizacion-heading" class="font-heading text-5xl sm:text-6xl text-white mb-4 mt-2">
        AGENDA TU DIAGNÓSTICO
      </h2>
      <p class="text-slate-400 text-lg leading-relaxed">
        Completa el formulario y un ingeniero senior te contactará en menos de 24 h hábiles.
        Diagnóstico inicial sin costo y sin compromiso.
      </p>
    </header>

    <div class="bento-card p-6 sm:p-10 reveal">
      <form
        id="cotizacion-form"
        class="space-y-6"
        novalidate
        aria-label="Formulario de solicitud de cotización"
      >
        <!-- Honeypot -->
        <div class="hidden" aria-hidden="true">
          <label for="cot-website">Sitio web (no completar)</label>
          <input type="text" id="cot-website" name="website" tabindex="-1" autocomplete="off" />
        </div>

        <div class="grid sm:grid-cols-2 gap-5">
          <!-- Empresa -->
          <div class="space-y-1.5">
            <label for="cot-empresa" class="block text-sm font-medium text-slate-300">
              Empresa / Razón social <span class="text-rose-400" aria-hidden="true">*</span>
            </label>
            <input
              type="text"
              id="cot-empresa"
              name="empresa"
              required
              maxlength="120"
              autocomplete="organization"
              placeholder="Ej. Industrias del Norte S.A."
              class="w-full px-4 py-3 rounded-xl bg-surface-700 border border-white/10 text-white placeholder-slate-500 text-sm transition-colors duration-200 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500"
              aria-required="true"
            />
            <p class="text-rose-400 text-xs min-h-[1rem]" id="cot-empresa-error" role="alert" aria-live="polite"></p>
          </div>

          <!-- Contacto -->
          <div class="space-y-1.5">
            <label for="cot-contacto" class="block text-sm font-medium text-slate-300">
              Nombre del contacto <span class="text-rose-400" aria-hidden="true">*</span>
            </label>
            <input
              type="text"
              id="cot-contacto"
              name="contacto"
              required
              minlength="2"
              maxlength="100"
              autocomplete="name"
              placeholder="Ing. Carlos García"
              class="w-full px-4 py-3 rounded-xl bg-surface-700 border border-white/10 text-white placeholder-slate-500 text-sm transition-colors duration-200 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500"
              aria-required="true"
            />
            <p class="text-rose-400 text-xs min-h-[1rem]" id="cot-contacto-error" role="alert" aria-live="polite"></p>
          </div>

          <!-- Email -->
          <div class="space-y-1.5">
            <label for="cot-email" class="block text-sm font-medium text-slate-300">
              Correo electrónico <span class="text-rose-400" aria-hidden="true">*</span>
            </label>
            <input
              type="email"
              id="cot-email"
              name="email"
              required
              maxlength="200"
              autocomplete="email"
              placeholder="contacto@empresa.com"
              class="w-full px-4 py-3 rounded-xl bg-surface-700 border border-white/10 text-white placeholder-slate-500 text-sm transition-colors duration-200 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500"
              aria-required="true"
            />
            <p class="text-rose-400 text-xs min-h-[1rem]" id="cot-email-error" role="alert" aria-live="polite"></p>
          </div>

          <!-- Teléfono -->
          <div class="space-y-1.5">
            <label for="cot-telefono" class="block text-sm font-medium text-slate-300">
              Teléfono / WhatsApp <span class="text-rose-400" aria-hidden="true">*</span>
            </label>
            <input
              type="tel"
              id="cot-telefono"
              name="telefono"
              required
              maxlength="20"
              autocomplete="tel"
              placeholder="55 1234 5678"
              class="w-full px-4 py-3 rounded-xl bg-surface-700 border border-white/10 text-white placeholder-slate-500 text-sm transition-colors duration-200 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500"
              aria-required="true"
            />
            <p class="text-rose-400 text-xs min-h-[1rem]" id="cot-telefono-error" role="alert" aria-live="polite"></p>
          </div>

          <!-- Sector -->
          <div class="space-y-1.5">
            <label for="cot-sector" class="block text-sm font-medium text-slate-300">
              Sector <span class="text-rose-400" aria-hidden="true">*</span>
            </label>
            <select
              id="cot-sector"
              name="sector"
              required
              class="w-full px-4 py-3 rounded-xl bg-surface-700 border border-white/10 text-slate-300 text-sm transition-colors duration-200 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 appearance-none cursor-pointer"
              aria-required="true"
            >
              <option value="">Selecciona…</option>
              {sectores.map(s => (
                <option value={s.slug}>{s.nombre}</option>
              ))}
            </select>
          </div>

          <!-- Tipo de servicio -->
          <div class="space-y-1.5">
            <label for="cot-servicio" class="block text-sm font-medium text-slate-300">
              Tipo de servicio <span class="text-rose-400" aria-hidden="true">*</span>
            </label>
            <select
              id="cot-servicio"
              name="servicio"
              required
              class="w-full px-4 py-3 rounded-xl bg-surface-700 border border-white/10 text-slate-300 text-sm transition-colors duration-200 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 appearance-none cursor-pointer"
              aria-required="true"
            >
              <option value="">Selecciona…</option>
              {servicios.map(s => (
                <option value={s.slug} selected={preselectedServicio === s.slug}>
                  {s.titulo}
                </option>
              ))}
              <option value="otro">Otro / No estoy seguro</option>
            </select>
          </div>

          <!-- Urgencia -->
          <div class="space-y-1.5 sm:col-span-2">
            <fieldset>
              <legend class="block text-sm font-medium text-slate-300 mb-2">
                Urgencia <span class="text-rose-400" aria-hidden="true">*</span>
              </legend>
              <div class="grid sm:grid-cols-3 gap-3">
                {[
                  { val: 'baja',    label: 'Baja', sub: 'Más de 1 mes' },
                  { val: 'media',   label: 'Media', sub: '2–4 semanas' },
                  { val: 'alta',    label: 'Alta', sub: 'Esta semana' },
                ].map(u => (
                  <label class="relative flex flex-col gap-1 px-4 py-3 rounded-xl bg-surface-700 border border-white/10 cursor-pointer transition-colors duration-200 hover:border-blue-500/50 has-[:checked]:border-blue-500 has-[:checked]:bg-blue-900/20">
                    <input type="radio" name="urgencia" value={u.val} required class="sr-only peer" />
                    <span class="font-semibold text-white text-sm">{u.label}</span>
                    <span class="text-xs text-slate-400">{u.sub}</span>
                    <span class="absolute top-3 right-3 w-4 h-4 rounded-full border-2 border-white/30 peer-checked:border-blue-400 peer-checked:bg-blue-500" aria-hidden="true"></span>
                  </label>
                ))}
              </div>
            </fieldset>
          </div>
        </div>

        <!-- Descripción -->
        <div class="space-y-1.5">
          <label for="cot-descripcion" class="block text-sm font-medium text-slate-300">
            Descripción del proyecto / problema <span class="text-rose-400" aria-hidden="true">*</span>
          </label>
          <textarea
            id="cot-descripcion"
            name="descripcion"
            required
            minlength="20"
            maxlength="2500"
            rows="5"
            placeholder="Cuéntanos sobre la instalación, equipos involucrados, ubicación y resultado esperado…"
            class="w-full px-4 py-3 rounded-xl bg-surface-700 border border-white/10 text-white placeholder-slate-500 text-sm transition-colors duration-200 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 resize-y min-h-[8rem]"
            aria-required="true"
          ></textarea>
          <p class="text-rose-400 text-xs min-h-[1rem]" id="cot-descripcion-error" role="alert" aria-live="polite"></p>
        </div>

        <!-- Aviso privacidad -->
        <label class="flex items-start gap-3 text-sm text-slate-400 cursor-pointer">
          <input
            type="checkbox"
            id="cot-privacidad"
            name="privacidad"
            required
            class="mt-0.5 w-4 h-4 rounded border-white/20 bg-surface-700 text-blue-600 focus:ring-blue-500"
            aria-required="true"
          />
          <span>
            Acepto el tratamiento de mis datos personales con fines de contacto comercial,
            conforme al aviso de privacidad. <span class="text-rose-400">*</span>
          </span>
        </label>

        <!-- Submit -->
        <div class="flex flex-col sm:flex-row gap-3">
          <button
            type="submit"
            id="cot-submit"
            class="flex-1 inline-flex items-center justify-center gap-2 px-6 py-4 rounded-xl text-base font-bold text-white bg-blue-600 hover:bg-blue-500 disabled:opacity-60 disabled:cursor-not-allowed transition-all duration-200 shadow-lg hover:shadow-blue-600/30 hover:scale-[1.01] focus-visible:ring-2 focus-visible:ring-blue-400"
          >
            <svg id="cot-spinner" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="hidden w-5 h-5 animate-spin" aria-hidden="true">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
            <span id="cot-submit-text">Solicitar cotización</span>
          </button>

          <a
            href={waUrl('Hola, quisiera solicitar una cotización para mi proyecto.')}
            target="_blank"
            rel="noopener noreferrer"
            class="flex-1 sm:flex-initial inline-flex items-center justify-center gap-2 px-6 py-4 rounded-xl text-base font-semibold text-white bg-green-600 hover:bg-green-500 transition-all duration-200 shadow-lg hover:shadow-green-600/30 focus-visible:ring-2 focus-visible:ring-green-400"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp directo
          </a>
        </div>

        <!-- Status -->
        <div
          id="cot-status"
          class="hidden rounded-xl px-4 py-3 text-sm font-medium"
          role="status"
          aria-live="polite"
        ></div>
      </form>
    </div>

  </div>
</section>

<script>
  const form    = document.getElementById('cotizacion-form') as HTMLFormElement | null;
  const spinner = document.getElementById('cot-spinner');
  const btnText = document.getElementById('cot-submit-text');
  const btnEl   = document.getElementById('cot-submit') as HTMLButtonElement | null;
  const status  = document.getElementById('cot-status');

  const setError = (id: string, msg: string) => {
    const el    = document.getElementById(`cot-${id}-error`);
    const input = document.getElementById(`cot-${id}`);
    if (el) el.textContent = msg;
    if (input) {
      input.classList.toggle('border-rose-500', !!msg);
      input.classList.toggle('border-white/10', !msg);
    }
  };

  const validators: Record<string, (v: string) => string> = {
    empresa:     v => v.trim().length >= 2  ? '' : 'Ingresa la razón social (mín. 2 caracteres).',
    contacto:    v => v.trim().length >= 2  ? '' : 'Ingresa el nombre del contacto.',
    email:       v => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v.trim()) ? '' : 'Correo electrónico inválido.',
    telefono:    v => v.trim().length >= 7  ? '' : 'Ingresa un teléfono con mín. 7 dígitos.',
    descripcion: v => v.trim().length >= 20 ? '' : 'Describe tu proyecto (mín. 20 caracteres).',
  };

  form?.addEventListener('submit', async (e: Event) => {
    e.preventDefault();
    const honeypot = (form.elements.namedItem('website') as HTMLInputElement)?.value;
    if (honeypot) return;

    const data = new FormData(form);
    let valid = true;

    for (const [field, validate] of Object.entries(validators)) {
      const val = data.get(field) as string ?? '';
      const err = validate(val);
      setError(field, err);
      if (err) valid = false;
    }

    if (!valid) return;

    if (btnEl) btnEl.disabled = true;
    if (spinner) spinner.classList.remove('hidden');
    if (btnText) btnText.textContent = 'Enviando…';

    await new Promise(r => setTimeout(r, 1200));

    if (btnEl) btnEl.disabled = false;
    if (spinner) spinner.classList.add('hidden');
    if (btnText) btnText.textContent = 'Solicitar cotización';

    if (status) {
      status.classList.remove('hidden', 'bg-rose-900/40', 'text-rose-300', 'bg-green-900/40', 'text-green-300');
      status.classList.add('bg-green-900/40', 'text-green-300');
      status.textContent = '¡Solicitud enviada! Un ingeniero senior te contactará en menos de 24 h hábiles.';
    }
    form.reset();
    Object.keys(validators).forEach(f => setError(f, ''));
  });
</script>
