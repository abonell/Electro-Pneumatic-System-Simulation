---
import { servicios } from '../data/servicios';
import { waUrl, url } from '../data/site';

interface Props {
  /** Show "Ver todos los servicios" link to /servicios. */
  showAllLink?: boolean;
  /** Override the section heading. */
  heading?: string;
  /** Override the eyebrow text. */
  eyebrow?: string;
}

const {
  showAllLink = false,
  heading = 'NUESTROS SERVICIOS',
  eyebrow = 'LO QUE HACEMOS',
} = Astro.props;
---

<section id="servicios" class="py-24 lg:py-32 bg-surface-800" aria-labelledby="servicios-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <header class="text-center max-w-2xl mx-auto mb-16 reveal">
      <p class="font-sub text-sm tracking-widest mb-3 section-eyebrow inline-flex text-blue-400">{eyebrow}</p>
      <h2 id="servicios-heading" class="font-heading text-5xl sm:text-6xl text-white mb-4">
        {heading}
      </h2>
      <p class="text-slate-400 text-lg leading-relaxed">
        Soluciones técnicas integrales para industria, comercio y hogar. Cada proyecto con el respaldo de
        décadas de experiencia en campo.
      </p>
    </header>

    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5 reveal-stagger"
      role="list"
      aria-label="Lista de servicios"
    >
      {servicios.map(svc => {
        const isFeatured = svc.featured;
        return (
          <article
            role="listitem"
            class={`bento-card group flex flex-col overflow-hidden ${isFeatured ? 'lg:col-span-2' : 'lg:col-span-2 xl:col-span-1'}`}
          >
            <a
              href={url(`/servicio/${svc.slug}`)}
              class="relative overflow-hidden flex-shrink-0 block focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-400"
              aria-label={`Ver detalle: ${svc.titulo}`}
              style={`height: ${isFeatured ? '16rem' : '12rem'}`}
            >
              <img
                src={svc.imagen}
                alt={svc.imagenAlt}
                width={isFeatured ? 1200 : 800}
                height={isFeatured ? 800 : 533}
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.04] img-blur-up"
              />
              <div class="absolute top-3 left-3 flex items-center justify-center w-9 h-9 rounded-lg glass-panel shadow-lg">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-blue-300" aria-hidden="true">
                  <path d={svc.iconPath}/>
                </svg>
              </div>
              <div class="absolute inset-0 bg-gradient-to-t from-surface-card via-transparent to-transparent opacity-75"></div>
            </a>

            <div class="flex flex-col flex-1 p-6">
              <h3 class="font-heading text-2xl text-white mb-3 group-hover:text-blue-300 transition-colors duration-200">
                <a href={url(`/servicio/${svc.slug}`)} class="focus-visible:outline-none focus-visible:underline">
                  {svc.titulo}
                </a>
              </h3>
              <p class="text-slate-400 text-sm leading-relaxed flex-1 mb-4">
                {svc.descripcionCorta}
              </p>
              <ul class="flex flex-wrap gap-2 mb-5" aria-label={`Especialidades de ${svc.titulo}`} role="list">
                {svc.tags.map(tag => (
                  <li class="px-2.5 py-1 rounded-full text-xs font-medium bg-blue-900/40 text-blue-300 border border-blue-700/30">
                    {tag}
                  </li>
                ))}
              </ul>

              <div class="flex flex-wrap items-center gap-4">
                <a
                  href={url(`/servicio/${svc.slug}`)}
                  class="animated-underline inline-flex items-center gap-1.5 text-sm font-semibold text-blue-300 hover:text-blue-200 transition-colors duration-200"
                  aria-label={`Ver detalle del servicio: ${svc.titulo}`}
                >
                  Ver detalle
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5" aria-hidden="true">
                    <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/>
                  </svg>
                </a>

                <a
                  href={waUrl(`Hola, me interesa el servicio de: ${svc.titulo}. ¿Pueden darme más información?`)}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 text-sm font-semibold text-green-400 hover:text-green-300 transition-colors duration-200"
                  aria-label={`Consultar por WhatsApp: ${svc.titulo}`}
                >
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4" aria-hidden="true">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                  </svg>
                  WhatsApp
                </a>
              </div>
            </div>
          </article>
        );
      })}
    </div>

    {showAllLink && (
      <div class="text-center mt-12 reveal">
        <a
          href={url('/cotizacion')}
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl text-sm font-semibold text-white bg-blue-600 hover:bg-blue-500 transition-all duration-200 shadow-lg hover:shadow-blue-600/30 focus-visible:ring-2 focus-visible:ring-blue-400 group"
        >
          Solicitar cotización
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-200" aria-hidden="true">
            <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/>
          </svg>
        </a>
      </div>
    )}
  </div>
</section>
