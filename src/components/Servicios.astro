    icon: `<path d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25"/>`,
    title: 'Modernización Tecnológica',
    desc:  'Reemplazo de tecnologías obsoletas por soluciones modernas y seguras. Migración de relés a PLC, actualización de HMI, integración SCADA y comunicación industrial.',
    tags:  ['PLC upgrade', 'SCADA', 'HMI', 'Industria 4.0'],
    img:   'https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&w=800&q=75&fm=webp',
    imgAlt: 'Placa de circuito electrónico de control industrial con componentes de precisión',
    featured: true,
  },
  {
    icon: `<path d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5"/>`,
    title: 'Capacitación Técnica',
    desc:  'Programas de formación profesional en electroneumática, automatización y PLC. Bancos de prueba didácticos, certificaciones y acompañamiento continuo para tu equipo.',
    tags:  ['PLC básico/avanzado', 'Neumática', 'Cursos presenciales', 'Certificación'],
    img:   'https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&w=800&q=75&fm=webp',
    imgAlt: 'Grupo de profesionales en sesión de capacitación técnica con material didáctico',
  },
];
---

<section id="servicios" class="py-24 lg:py-32 bg-surface-800" aria-labelledby="servicios-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <header class="text-center max-w-2xl mx-auto mb-16 reveal">
      <p class="font-sub text-sm tracking-widest mb-3 section-eyebrow inline-flex text-blue-400">LO QUE HACEMOS</p>
      <h2 id="servicios-heading" class="font-heading text-5xl sm:text-6xl text-white mb-4">
        NUESTROS SERVICIOS
      </h2>
      <p class="text-slate-400 text-lg leading-relaxed">
        Soluciones técnicas integrales para industria, comercio y hogar. Cada proyecto con el respaldo de décadas de experiencia en campo.
      </p>
    </header>

    <!-- Bento grid — asymmetric layout: featured cards span 2 cols on lg -->
    <!-- Row 1: featured[0] (lg:col-span-2) + card[1] + card[2] — 4-col grid trick -->
    <!-- Row 2: card[3] + featured[4] (lg:col-span-2) + card[5] -->
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5 reveal-stagger"
      role="list"
      aria-label="Lista de servicios"
    >
      {services.map((svc, i) => {
        const isFeatured = svc.featured;
        return (
          <article
            role="listitem"
            class={`bento-card group flex flex-col overflow-hidden ${isFeatured ? 'lg:col-span-2' : 'lg:col-span-2 xl:col-span-1'}`}
          >
            <!-- Image -->
            <div class={`relative overflow-hidden flex-shrink-0 ${isFeatured ? 'h-56 lg:h-64' : 'h-48'}`}>
              <img
                src={svc.img}
                alt={svc.imgAlt}
                width={isFeatured ? 1200 : 800}
                height={isFeatured ? 800 : 533}
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.04] img-blur-up"
              />
              <!-- Icon badge — glassmorphism -->
              <div class="absolute top-3 left-3 flex items-center justify-center w-9 h-9 rounded-lg glass-panel shadow-lg">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-blue-300" aria-hidden="true">
                  <Fragment set:html={svc.icon} />
                </svg>
              </div>
              <!-- Overlay gradient -->
              <div class="absolute inset-0 bg-gradient-to-t from-surface-card via-transparent to-transparent opacity-75"></div>
            </div>

            <!-- Content -->
            <div class="flex flex-col flex-1 p-6">
              <h3 class="font-heading text-2xl text-white mb-3 group-hover:text-blue-300 transition-colors duration-200">
                {svc.title}
              </h3>
              <p class="text-slate-400 text-sm leading-relaxed flex-1 mb-4">
                {svc.desc}
              </p>
              <!-- Tags -->
              <ul class="flex flex-wrap gap-2 mb-5" aria-label={`Especialidades de ${svc.title}`} role="list">
                {svc.tags.map(tag => (
                  <li class="px-2.5 py-1 rounded-full text-xs font-medium bg-blue-900/40 text-blue-300 border border-blue-700/30">
                    {tag}
                  </li>
                ))}
              </ul>
              <!-- CTA -->
              <a
                href={makeWA(svc.title)}
                target="_blank"
                rel="noopener noreferrer"
                class="animated-underline inline-flex items-center gap-2 text-sm font-semibold text-green-400 hover:text-green-300 transition-colors duration-200 group/link w-fit"
                aria-label={`Consultar por WhatsApp: ${svc.title}`}
              >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 flex-shrink-0" aria-hidden="true">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                Consultar por WhatsApp
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5 group-hover/link:translate-x-1 transition-transform duration-200" aria-hidden="true">
                  <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/>
                </svg>
              </a>
            </div>
          </article>
        );
      })}
    </div>

  </div>
</section>
