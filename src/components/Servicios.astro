---
const WA_NUMBER = '+526692629862'; // TODO: replace before launch
const makeWA = (svc: string) =>
  `https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(`Hola, me interesa el servicio de: ${svc}. ¿Pueden darme más información?`)}`;

interface Service {
  icon: string;
  title: string;
  desc: string;
  tags: string[];
  img: string;
  imgAlt: string;
  /** true → large bento tile (col-span-2 on lg) */
  featured?: boolean;
}

// Images audited for theme match and resolution:
// [0] photo-1565008447742 — electrical panel wiring closeup (industrial, on-theme)
// [1] photo-1558618666  — smart home tablet control (domotica)
// [2] photo-1572021335469 — electrician at panel (instalaciones)
// [3] photo-1504328345606 — technician with laptop on machinery (mantenimiento)
// [4] photo-1518770660439 — circuit board / PLC environment (modernización)
// [5] photo-1522202176988 — training / classroom engineering (capacitación)

const services: Service[] = [
  {
    icon: `<path d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>`,
    title: 'Electroneumática Industrial',
    desc:  'Diseño, instalación y mantenimiento de sistemas electroneumáticos para automatización de procesos. Circuitos de mando, actuadores, válvulas y sensores integrados con precisión.',
    tags:  ['Circuitos neumáticos', 'PLC', 'Sensórica', 'Válvulas'],
    img:   'https://images.unsplash.com/photo-1565008447742-97f6f38c985c?auto=format&fit=crop&w=1200&q=80&fm=webp',
    imgAlt: 'Tablero de conexiones eléctricas industriales con cableado multicolor',
    featured: true,
  },
  {
    icon: `<path d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/>`,
    title: 'Domótica e Instalaciones del Hogar',
    desc:  'Automatización residencial inteligente: control de iluminación, climatización, seguridad y acceso. Integración con asistentes de voz y aplicaciones móviles.',
    tags:  ['Smart Home', 'Control por app', 'Seguridad', 'IoT'],
    img:   'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&w=800&q=75&fm=webp',
    imgAlt: 'Tableta con interfaz de control de hogar inteligente sobre mesa moderna',
  },
  {
    icon: `<path fill-rule="evenodd" d="M14.615 1.595a.75.75 0 01.359.852L12.982 9.75h7.268a.75.75 0 01.548 1.262l-10.5 11.25a.75.75 0 01-1.272-.71l1.992-7.302H3.818a.75.75 0 01-.548-1.262l10.5-11.25a.75.75 0 01.845-.143z" clip-rule="evenodd"/>`,
    title: 'Instalaciones Eléctricas',
    desc:  'Instalaciones eléctricas residenciales, comerciales e industriales. Subestaciones, tableros de distribución, corriente normal y regulada. NOM-001-SEDE compliant.',
    tags:  ['Residencial', 'Industrial', 'Subestaciones', 'NOM-001-SEDE'],
    img:   'https://images.unsplash.com/photo-1621905251189-08b45d6a269e?auto=format&fit=crop&w=800&q=75&fm=webp',
    imgAlt: 'Electricista instalando cableado en tablero de distribución industrial',
  },
  {
    icon: `<path d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z"/><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>`,
    title: 'Contratos de Mantenimiento',
    desc:  'Planes de mantenimiento preventivo y correctivo para equipos industriales. Garantizamos máxima disponibilidad operativa y reducimos costos por paro no programado.',
