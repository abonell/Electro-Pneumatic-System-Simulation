---
// TODO: replace WA_NUMBER with real WhatsApp business number before launch
const WA_NUMBER = '+526692629862';
const WA_MSG    = encodeURIComponent('Hola, me interesa obtener una asesoría gratuita sobre sus servicios de automatización e instalaciones eléctricas.');
const WA_HREF   = `https://wa.me/${WA_NUMBER}?text=${WA_MSG}`;

const stats = [
  { value: '34+',  label: 'Años de experiencia' },
  { value: '500+', label: 'Proyectos entregados' },
  { value: '98%',  label: 'Clientes satisfechos' },
];
---

<section
  id="inicio"
  class="relative min-h-screen flex items-center pt-16 overflow-hidden"
  aria-label="Sección principal"
>
  <!-- Background hero image with overlay -->
  <div class="absolute inset-0 z-0" aria-hidden="true">
    <img
      src="https://images.unsplash.com/photo-1518770660439-4636190af475?w=1400&auto=format&fit=crop&q=80"
      alt=""
      width="1400"
      height="933"
      class="w-full h-full object-cover object-center"
      fetchpriority="high"
      decoding="async"
    />
    <!-- Dark gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-r from-surface-900/95 via-surface-900/80 to-surface-900/40"></div>
    <!-- Bottom fade -->
    <div class="absolute bottom-0 inset-x-0 h-48 bg-gradient-to-t from-surface-900 to-transparent"></div>
    <!-- Ambient blue glow -->
    <div class="absolute top-1/3 left-1/4 w-96 h-96 bg-blue-700/20 rounded-full blur-3xl"></div>
  </div>

  <!-- Animated grid lines (decorative) -->
  <div
    class="absolute inset-0 z-0 opacity-5"
    style="background-image: linear-gradient(rgba(59,130,246,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(59,130,246,0.5) 1px, transparent 1px); background-size: 60px 60px;"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
    <div class="max-w-3xl">

      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-3 py-1.5 mb-6 rounded-full border border-blue-500/30 bg-blue-500/10 text-blue-300 text-xs font-sub tracking-widest">
        <span class="w-1.5 h-1.5 rounded-full bg-blue-400 animate-pulse" aria-hidden="true"></span>
        34 AÑOS DE EXPERIENCIA EN AUTOMATIZACIÓN
      </div>

      <!-- Headline -->
      <h1 class="font-heading text-5xl sm:text-6xl lg:text-7xl xl:text-8xl text-white mb-6">
        INGENIERÍA&nbsp;QUE<br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-cyan-400">
          TRANSFORMA
        </span><br/>
        TU EMPRESA
      </h1>

      <!-- Subheadline -->
      <p class="text-lg sm:text-xl text-slate-300 mb-8 max-w-2xl leading-relaxed">
        Somos especialistas en <strong class="text-white font-semibold">electroneumática</strong>,
        <strong class="text-white font-semibold">domótica</strong> e
        <strong class="text-white font-semibold">instalaciones eléctricas</strong>.
        Modernizamos y mantenemos sistemas industriales y residenciales con precisión,
        seguridad y respaldo técnico de primer nivel.
      </p>

      <!-- CTA buttons -->
      <div class="flex flex-col sm:flex-row gap-4 mb-14">
        <!-- Primary: WhatsApp -->
        <a
          href={WA_HREF}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-3 px-7 py-4 rounded-xl text-base font-bold text-white bg-green-600 hover:bg-green-500 transition-all duration-200 shadow-lg hover:shadow-green-600/40 hover:scale-[1.02] focus-visible:ring-2 focus-visible:ring-green-400 group"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 group-hover:scale-110 transition-transform duration-200 flex-shrink-0" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Solicitar asesoría gratis
        </a>

        <!-- Secondary: scroll to services -->
        <a
          href="#servicios"
          class="inline-flex items-center justify-center gap-2 px-7 py-4 rounded-xl text-base font-semibold text-white border border-white/20 hover:border-blue-400/60 hover:bg-white/5 transition-all duration-200 focus-visible:ring-2 focus-visible:ring-blue-400"
        >
          Ver servicios
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 3a.75.75 0 01.75.75v10.638l3.96-4.158a.75.75 0 111.08 1.04l-5.25 5.5a.75.75 0 01-1.08 0l-5.25-5.5a.75.75 0 111.08-1.04l3.96 4.158V3.75A.75.75 0 0110 3z" clip-rule="evenodd"/>
          </svg>
        </a>
      </div>

      <!-- Stats strip -->
      <dl class="flex flex-wrap gap-8">
        {stats.map(s => (
          <div class="flex flex-col">
            <dt class="font-heading text-4xl text-white">{s.value}</dt>
            <dd class="font-sub text-xs text-blue-300 tracking-widest mt-1">{s.label}</dd>
          </div>
        ))}
      </dl>

    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 hidden sm:flex flex-col items-center gap-2 text-slate-500 text-xs font-sub tracking-widest animate-bounce"
    aria-hidden="true"
  >
    <span>DESPLAZA</span>
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
      <path fill-rule="evenodd" d="M10 3a.75.75 0 01.75.75v10.638l3.96-4.158a.75.75 0 111.08 1.04l-5.25 5.5a.75.75 0 01-1.08 0l-5.25-5.5a.75.75 0 111.08-1.04l3.96 4.158V3.75A.75.75 0 0110 3z" clip-rule="evenodd"/>
    </svg>
  </div>
</section>
