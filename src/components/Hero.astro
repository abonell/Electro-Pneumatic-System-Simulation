---
// TODO: replace WA_NUMBER with real WhatsApp business number before launch
const WA_NUMBER = '+526692629862';
const WA_MSG    = encodeURIComponent('Hola, me interesa obtener una asesoría gratuita sobre sus servicios de automatización e instalaciones eléctricas.');
const WA_HREF   = `https://wa.me/${WA_NUMBER}?text=${WA_MSG}`;

const stats = [
  { value: 34,  suffix: '+', label: 'Años de experiencia' },
  { value: 500, suffix: '+', label: 'Proyectos entregados' },
  { value: 98,  suffix: '%', label: 'Clientes satisfechos' },
];
---

<section
  id="inicio"
  class="relative min-h-screen flex items-center pt-16 overflow-hidden"
  aria-label="Sección principal"
>
  <!-- Brand-aligned background — pure CSS, zero image weight -->
  <!-- Deep electric navy base with diagonal energy gradient; light-mode overridden via .hero-bg-gradient -->
  <div
    class="hero-bg-gradient absolute inset-0 z-0"
    style="background:
      radial-gradient(ellipse 90% 60% at 80% 0%, rgba(34,211,238,0.18), transparent 60%),
      radial-gradient(ellipse 70% 70% at 0% 100%, rgba(59,130,246,0.20), transparent 55%),
      linear-gradient(135deg, #050917 0%, #0a1633 45%, #0a1f44 75%, #050917 100%);"
    aria-hidden="true"
  ></div>

  <!-- Aurora orbs (CSS-only, defined in global.css) -->
  <div class="hero-aurora" aria-hidden="true">
    <div class="hero-aurora-c"></div>
  </div>

  <!-- Engineering circuit pattern — branded, vector, lightweight -->
  <svg
    class="hero-circuit-pattern absolute inset-0 w-full h-full z-0 opacity-[0.18] pointer-events-none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
    preserveAspectRatio="xMidYMid slice"
  >
    <defs>
      <pattern id="circuit-grid" x="0" y="0" width="120" height="120" patternUnits="userSpaceOnUse">
        <!-- Trace lines -->
        <path d="M0 30 H50 V0 M50 30 H120 M0 90 H80 V120 M80 90 H120 M30 0 V40 H90" stroke="rgba(34,211,238,0.55)" stroke-width="1" fill="none"/>
        <!-- Nodes -->
        <circle cx="50" cy="30" r="2.5" fill="rgba(96,165,250,0.9)"/>
        <circle cx="80" cy="90" r="2.5" fill="rgba(34,211,238,0.85)"/>
        <circle cx="30" cy="40" r="1.8" fill="rgba(96,165,250,0.7)"/>
        <circle cx="90" cy="40" r="1.8" fill="rgba(34,211,238,0.7)"/>
      </pattern>
      <linearGradient id="circuit-fade" x1="0" x2="1" y1="0" y2="1">
        <stop offset="0%" stop-color="white" stop-opacity="0.05"/>
        <stop offset="50%" stop-color="white" stop-opacity="0.9"/>
        <stop offset="100%" stop-color="white" stop-opacity="0.1"/>
      </linearGradient>
      <mask id="circuit-mask">
        <rect width="100%" height="100%" fill="url(#circuit-fade)"/>
      </mask>
    </defs>
    <rect width="100%" height="100%" fill="url(#circuit-grid)" mask="url(#circuit-mask)"/>
  </svg>

  <!-- Animated energy traces — diagonal beams (perf-cheap, GPU) -->
  <div class="hero-energy-beams" aria-hidden="true">
    <span class="beam beam-a"></span>
    <span class="beam beam-b"></span>
    <span class="beam beam-c"></span>
  </div>

  <!-- Bottom fade into next section -->
  <div class="hero-bottom-fade absolute bottom-0 inset-x-0 h-40 bg-gradient-to-t from-surface-900 to-transparent z-0" aria-hidden="true"></div>

  <!-- Spotlight cursor-follow (JS target in Layout) -->
  <div class="hero-spotlight" aria-hidden="true"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
    <div class="max-w-3xl">

      <!-- Eyebrow badge -->
      <div
        class="inline-flex items-center gap-2 px-3 py-1.5 mb-7 rounded-full border border-blue-500/30 bg-blue-500/10 text-blue-300 text-xs font-sub tracking-widest reveal"
        aria-label="34 años de experiencia en automatización"
      >
        <span class="w-1.5 h-1.5 rounded-full bg-blue-400 animate-pulse" aria-hidden="true"></span>
        34 AÑOS DE EXPERIENCIA EN AUTOMATIZACIÓN
      </div>

      <!-- Headline — word-by-word reveal (CSS animation) -->
      <!-- Each span.hero-word gets staggered entry via global.css -->
      <h1 class="font-heading text-5xl sm:text-6xl lg:text-7xl xl:text-8xl text-white mb-6" aria-label="Ingeniería que transforma tu empresa">
        <span class="hero-word">INGENIERÍA&nbsp;</span><span class="hero-word">QUE</span><br class="hidden sm:block"/>
        <span class="hero-word">
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-cyan-400 to-blue-300">
            TRANSFORMA
          </span>
        </span><br/>
        <span class="hero-word">TU&nbsp;</span><span class="hero-word">EMPRESA</span>
      </h1>

      <!-- Subheadline -->
      <p class="text-lg sm:text-xl text-slate-300 mb-9 max-w-2xl leading-relaxed reveal" style="--reveal-delay:0.3s">
        Somos especialistas en <strong class="text-white font-semibold">electroneumática</strong>,
        <strong class="text-white font-semibold">domótica</strong> e
        <strong class="text-white font-semibold">instalaciones eléctricas</strong>.
        Modernizamos y mantenemos sistemas industriales y residenciales con precisión,
        seguridad y respaldo técnico de primer nivel.
      </p>

      <!-- CTA buttons -->
      <div class="flex flex-col sm:flex-row gap-4 mb-14 reveal">
        <!-- Primary: WhatsApp — magnetic -->
        <a
          href={WA_HREF}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-magnetic inline-flex items-center justify-center gap-3 px-7 py-4 rounded-xl text-base font-bold text-white bg-green-600 hover:bg-green-500 transition-all duration-200 shadow-lg hover:shadow-green-600/40 hover:scale-[1.03] focus-visible:ring-2 focus-visible:ring-green-400 group"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 group-hover:scale-110 transition-transform duration-200 flex-shrink-0" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Solicitar asesoría gratis
        </a>

        <!-- Secondary: scroll to services -->
        <a
          href="#servicios"
          class="inline-flex items-center justify-center gap-2 px-7 py-4 rounded-xl text-base font-semibold text-white border border-white/20 hover:border-blue-400/60 hover:bg-white/5 transition-all duration-200 focus-visible:ring-2 focus-visible:ring-blue-400 group"
        >
          Ver servicios
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 group-hover:translate-y-0.5 transition-transform duration-200" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 3a.75.75 0 01.75.75v10.638l3.96-4.158a.75.75 0 111.08 1.04l-5.25 5.5a.75.75 0 01-1.08 0l-5.25-5.5a.75.75 0 111.08-1.04l3.96 4.158V3.75A.75.75 0 0110 3z" clip-rule="evenodd"/>
          </svg>
        </a>
      </div>

      <!-- Stats strip — count-up via data-countup + JS in Layout -->
      <dl class="flex flex-wrap gap-8 reveal">
        {stats.map(s => (
          <div class="flex flex-col">
            <dt class="font-heading text-4xl text-white leading-none">
              <span
                class="stat-counter"
                data-countup={s.value}
                data-suffix={s.suffix}
                aria-label={`${s.value}${s.suffix}`}
              >{s.value}{s.suffix}</span>
            </dt>
            <dd class="font-sub text-xs text-blue-300 tracking-widest mt-1">{s.label}</dd>
          </div>
        ))}
      </dl>

    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    class="hero-scroll-indicator absolute bottom-8 left-1/2 -translate-x-1/2 z-10 hidden sm:flex flex-col items-center gap-2 text-slate-500 text-xs font-sub tracking-widest"
    aria-hidden="true"
    style="animation: float-bounce 2s ease-in-out infinite;"
  >
    <span>DESPLAZA</span>
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
      <path fill-rule="evenodd" d="M10 3a.75.75 0 01.75.75v10.638l3.96-4.158a.75.75 0 111.08 1.04l-5.25 5.5a.75.75 0 01-1.08 0l-5.25-5.5a.75.75 0 111.08-1.04l3.96 4.158V3.75A.75.75 0 0110 3z" clip-rule="evenodd"/>
    </svg>
  </div>
</section>

<style>
  @keyframes float-bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50%       { transform: translateX(-50%) translateY(6px); }
  }

  /* ── Energy beams ── diagonal trails sweeping across hero ── */
  .hero-energy-beams {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
    pointer-events: none;
  }
  .hero-energy-beams .beam {
    position: absolute;
    top: -20%;
    height: 140%;
    width: 1px;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(34, 211, 238, 0.0) 20%,
      rgba(34, 211, 238, 0.85) 50%,
      rgba(34, 211, 238, 0.0) 80%,
      transparent 100%
    );
    transform: rotate(15deg);
    transform-origin: top center;
    filter: drop-shadow(0 0 6px rgba(34, 211, 238, 0.6));
    animation: beam-sweep 9s linear infinite;
  }
  .beam-a { left: 15%; animation-delay: 0s;   }
  .beam-b { left: 55%; animation-delay: -3s;  background: linear-gradient(to bottom, transparent, rgba(96,165,250,0.75) 50%, transparent); }
  .beam-c { left: 82%; animation-delay: -6s; }

  @keyframes beam-sweep {
    0%   { opacity: 0; transform: translateY(-40%) rotate(15deg); }
    10%  { opacity: 1; }
    90%  { opacity: 1; }
    100% { opacity: 0; transform: translateY(40%) rotate(15deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    [style*="float-bounce"]    { animation: none !important; }
    .hero-energy-beams .beam   { animation: none !important; opacity: 0.4; }
  }
</style>
