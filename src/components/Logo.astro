---
/**
 * Logo.astro — Electroneumática Interactiva brand mark
 *
 * Concept: Lightning bolt fused with a circuit trace and a pneumatic valve body.
 * The bolt provides energy/power reading; the horizontal circuit lines evoke PCB
 * traces and pneumatic line diagrams simultaneously; the central node dot reads
 * as a smart-home node or solenoid port.
 *
 * Usage variants:
 *   <Logo />                   → icon mark only (square, default 40×40)
 *   <Logo wordmark />           → icon + wordmark side-by-side
 *   <Logo wordmark stacked />   → icon + wordmark stacked (footer/hero use)
 *   <Logo favicon />            → simplified 32×32 favicon mark
 *
 * Color: uses currentColor so parent can set text-* class to recolor.
 * The accent slot (cyan node) uses a fixed accent variable for contrast.
 */

interface Props {
  wordmark?: boolean;
  stacked?: boolean;
  favicon?: boolean;
  class?: string;
  size?: number;
}

const {
  wordmark = false,
  stacked  = false,
  favicon  = false,
  class: className = '',
  size = 40,
} = Astro.props;
---

{favicon ? (
  <!-- Favicon variant: 32×32, solid bg, simplified mark -->
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 32 32"
    fill="none"
    role="img"
    aria-label="Electroneumática Interactiva"
    class={className}
    width="32"
    height="32"
  >
    <!-- Background square -->
    <rect width="32" height="32" rx="7" fill="#0d1225"/>
    <!-- Circuit trace left arm -->
    <line x1="3" y1="16" x2="9" y2="16" stroke="#22d3ee" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="9" y1="16" x2="9" y2="12" stroke="#22d3ee" stroke-width="1.5" stroke-linecap="round"/>
    <!-- Circuit trace right arm -->
    <line x1="23" y1="16" x2="29" y2="16" stroke="#22d3ee" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="23" y1="16" x2="23" y2="20" stroke="#22d3ee" stroke-width="1.5" stroke-linecap="round"/>
    <!-- Central bolt body -->
    <path
      d="M18.6 5.5 L13 16h5.5L14.2 26.5"
      stroke="white"
      stroke-width="2.2"
      stroke-linecap="round"
      stroke-linejoin="round"
      fill="none"
    />
    <!-- Node dot -->
    <circle cx="16" cy="16" r="2" fill="#22d3ee"/>
  </svg>
) : wordmark ? (
  <span class={`inline-flex ${stacked ? 'flex-col items-center gap-2' : 'items-center gap-3'} ${className}`}>
    <!-- Icon mark -->
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 44 44"
      fill="none"
      role="img"
      aria-hidden="true"
      width={size}
      height={size}
      class="flex-shrink-0"
    >
      <!-- Background rounded square with subtle gradient -->
      <rect width="44" height="44" rx="10" fill="url(#logo-bg-grad)"/>
      <defs>
        <linearGradient id="logo-bg-grad" x1="0" y1="0" x2="44" y2="44" gradientUnits="userSpaceOnUse">
          <stop offset="0%" stop-color="#1e3a8a"/>
          <stop offset="100%" stop-color="#0d1225"/>
        </linearGradient>
      </defs>
      <!-- Left circuit trace: short horizontal → vertical stub (valve port) -->
      <line x1="4"  y1="22" x2="12" y2="22" stroke="#22d3ee" stroke-width="1.8" stroke-linecap="round"/>
      <line x1="12" y1="22" x2="12" y2="17" stroke="#22d3ee" stroke-width="1.8" stroke-linecap="round"/>
      <circle cx="12" cy="16" r="1.5" fill="#22d3ee"/>
      <!-- Right circuit trace: horizontal → vertical stub (valve port) -->
      <line x1="40" y1="22" x2="32" y2="22" stroke="#22d3ee" stroke-width="1.8" stroke-linecap="round"/>
      <line x1="32" y1="22" x2="32" y2="27" stroke="#22d3ee" stroke-width="1.8" stroke-linecap="round"/>
      <circle cx="32" cy="28" r="1.5" fill="#22d3ee"/>
      <!-- Main lightning bolt — geometric, single-weight stroke -->
      <path
        d="M25 6 L17.5 22 H23.5 L20 38"
        stroke="white"
        stroke-width="2.8"
        stroke-linecap="round"
        stroke-linejoin="round"
        fill="none"
      />
      <!-- Central smart-node circle (where bolt intersects circuit plane) -->
      <circle cx="22" cy="22" r="3" fill="#22d3ee" opacity="0.9"/>
      <circle cx="22" cy="22" r="1.5" fill="white"/>
    </svg>

    <!-- Wordmark text -->
    {stacked ? (
      <span class="flex flex-col items-center leading-none gap-0.5">
        <span
          class="logo-wordmark-primary"
          style="font-family: var(--font-heading); letter-spacing: 0.08em; font-size: 1.15em; line-height: 1; color: white;"
        >ELECTRONEUMÁTICA</span>
        <span
          class="logo-wordmark-accent"
          style="font-family: var(--font-sub); letter-spacing: 0.2em; font-size: 0.6em; line-height: 1; color: #22d3ee;"
        >INTERACTIVA</span>
      </span>
    ) : (
      <span class="flex flex-col leading-none gap-0.5">
        <span
          class="logo-wordmark-primary"
          style="font-family: var(--font-heading); letter-spacing: 0.06em; font-size: 1.1em; line-height: 1; color: white;"
        >ELECTRONEUMÁTICA</span>
        <span
          class="logo-wordmark-accent"
          style="font-family: var(--font-sub); letter-spacing: 0.2em; font-size: 0.58em; line-height: 1; color: #22d3ee;"
        >INTERACTIVA</span>
      </span>
    )}
  </span>
) : (
  <!-- Icon mark only -->
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 44 44"
    fill="none"
    role="img"
    aria-label="Electroneumática Interactiva"
    width={size}
    height={size}
    class={className}
  >
    <rect width="44" height="44" rx="10" fill="url(#logo-bg-solo)"/>
    <defs>
      <linearGradient id="logo-bg-solo" x1="0" y1="0" x2="44" y2="44" gradientUnits="userSpaceOnUse">
        <stop offset="0%" stop-color="#1e3a8a"/>
        <stop offset="100%" stop-color="#0d1225"/>
      </linearGradient>
    </defs>
    <line x1="4"  y1="22" x2="12" y2="22" stroke="#22d3ee" stroke-width="1.8" stroke-linecap="round"/>
    <line x1="12" y1="22" x2="12" y2="17" stroke="#22d3ee" stroke-width="1.8" stroke-linecap="round"/>
    <circle cx="12" cy="16" r="1.5" fill="#22d3ee"/>
    <line x1="40" y1="22" x2="32" y2="22" stroke="#22d3ee" stroke-width="1.8" stroke-linecap="round"/>
    <line x1="32" y1="22" x2="32" y2="27" stroke="#22d3ee" stroke-width="1.8" stroke-linecap="round"/>
    <circle cx="32" cy="28" r="1.5" fill="#22d3ee"/>
    <path
      d="M25 6 L17.5 22 H23.5 L20 38"
      stroke="white"
      stroke-width="2.8"
      stroke-linecap="round"
      stroke-linejoin="round"
      fill="none"
    />
    <circle cx="22" cy="22" r="3" fill="#22d3ee" opacity="0.9"/>
    <circle cx="22" cy="22" r="1.5" fill="white"/>
  </svg>
)}
