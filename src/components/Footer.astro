---
import Logo from './Logo.astro';
import { SITE, waUrl, url } from '../data/site';
import { servicios } from '../data/servicios';

const year = new Date().getFullYear();

const navSections = [
  {
    heading: 'Servicios',
    links: servicios.map(s => ({
      label: s.titulo,
      href:  url(`/servicio/${s.slug}`),
    })),
  },
  {
    heading: 'Empresa',
    links: [
      { label: 'Inicio',      href: url('/') },
      { label: 'Servicios',   href: url('/servicios') },
      { label: 'Proyectos',   href: url('/proyectos') },
      { label: 'Cotización',  href: url('/cotizacion') },
      { label: 'Contacto',    href: url('/contacto') },
    ],
  },
];

const WA_HREF = waUrl();
const PHONE   = SITE.phones[0];
const EMAIL   = SITE.emails[0];
---

<footer class="bg-surface-900 border-t border-white/[0.05]" role="contentinfo" aria-label="Pie de página">

  <!-- Main footer grid -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 lg:py-20">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Brand column -->
      <div class="sm:col-span-2 lg:col-span-2">
        <a
          href={url('/')}
          class="inline-flex mb-5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-400 rounded-lg"
          aria-label="Electroneumática Interactiva — inicio"
        >
          <Logo wordmark size={36} />
        </a>

        <p class="text-slate-400 text-sm leading-relaxed max-w-sm mb-6">
          34 años de experiencia en automatización industrial, electroneumática, domótica e instalaciones eléctricas. Soluciones técnicas con el respaldo de quienes más han visto en campo.
        </p>

        <!-- Coverage badges -->
        <div class="flex flex-wrap gap-2 mb-6">
          {['Estado de México', 'CDMX', 'Zona Metropolitana'].map(area => (
            <span class="px-3 py-1 rounded-full text-xs font-sub tracking-wider text-slate-400 border border-slate-700">
              {area}
            </span>
          ))}
        </div>

        <!-- Contact quick links -->
        <div class="flex flex-col gap-2 text-sm">
          <a href={`tel:${PHONE.e164}`} class="animated-underline text-slate-400 hover:text-white transition-colors duration-200 flex items-center gap-2 w-fit">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 text-blue-500 flex-shrink-0" aria-hidden="true">
              <path fill-rule="evenodd" d="M2 3.5A1.5 1.5 0 013.5 2h1.148a1.5 1.5 0 011.465 1.175l.716 3.223a1.5 1.5 0 01-1.052 1.767l-.933.267c-.41.117-.643.555-.48.95a11.542 11.542 0 006.254 6.254c.395.163.833-.07.95-.48l.267-.933a1.5 1.5 0 011.767-1.052l3.223.716A1.5 1.5 0 0118 15.352V16.5a1.5 1.5 0 01-1.5 1.5H15c-1.149 0-2.263-.15-3.326-.43A13.022 13.022 0 012.43 8.326 13.019 13.019 0 012 5V3.5z" clip-rule="evenodd"/>
            </svg>
            {PHONE.display}
          </a>
          <a href={`mailto:${EMAIL.address}`} class="animated-underline text-slate-400 hover:text-white transition-colors duration-200 flex items-center gap-2 w-fit">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 text-blue-500 flex-shrink-0" aria-hidden="true">
              <path d="M3 4a2 2 0 00-2 2v1.161l8.441 4.221a1.25 1.25 0 001.118 0L19 7.162V6a2 2 0 00-2-2H3z"/>
              <path d="M19 8.839l-7.77 3.885a2.75 2.75 0 01-2.46 0L1 8.839V14a2 2 0 002 2h14a2 2 0 002-2V8.839z"/>
            </svg>
            {EMAIL.address}
          </a>
          <span class="text-slate-400 flex items-start gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 text-blue-500 flex-shrink-0 mt-0.5" aria-hidden="true">
              <path fill-rule="evenodd" d="M9.69 18.933l.003.001C9.89 19.02 10 19 10 19s.11.02.308-.066l.002-.001.006-.003.018-.008a5.741 5.741 0 00.281-.14c.186-.096.446-.24.757-.433.62-.384 1.445-.966 2.274-1.765C15.302 15.1 17 12.42 17 9A7 7 0 103 9c0 3.42 1.698 6.1 3.354 7.584a13.731 13.731 0 002.757 1.982l.018.008.006.003zM10 11.25a2.25 2.25 0 100-4.5 2.25 2.25 0 000 4.5z" clip-rule="evenodd"/>
            </svg>
            <span class="leading-snug">{SITE.address.street}<br/>{SITE.address.city}, {SITE.address.region} C.P. {SITE.address.postalCode}</span>
          </span>
        </div>
      </div>

      <!-- Nav columns -->
      {navSections.map(section => (
        <nav aria-label={`Footer — ${section.heading}`}>
          <h3 class="font-sub text-xs text-slate-500 tracking-widest mb-4">{section.heading.toUpperCase()}</h3>
          <ul class="space-y-2 list-none p-0 m-0">
            {section.links.map(link => (
              <li>
                <a
                  href={link.href}
                  class="animated-underline text-slate-400 hover:text-white text-sm transition-colors duration-200"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      ))}

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/[0.05]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-slate-500 text-xs text-center sm:text-left">
        &copy; {year} Electroneumática Interactiva. Todos los derechos reservados.
      </p>
      <div class="flex items-center gap-6">
        <a href={`${import.meta.env.BASE_URL}sitemap-index.xml`} class="animated-underline text-slate-500 hover:text-slate-400 text-xs transition-colors duration-200">Sitemap</a>
        <a
          href={WA_HREF}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 text-green-500 hover:text-green-400 text-xs font-medium transition-colors duration-200"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp
        </a>
      </div>
    </div>
  </div>

</footer>
