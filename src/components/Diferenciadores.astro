---
const differentiators = [
  {
    number: '01',
    title: 'Diagnóstico integral sin costo',
    desc: 'Antes de proponer cualquier solución, enviamos a un técnico senior a evaluar tu instalación completa. El diagnóstico y la cotización no tienen costo.',
    img: 'https://images.unsplash.com/photo-1565008447742-97f6f38c985c?w=900&auto=format&fit=crop&q=75',
    imgAlt: 'Técnico realizando diagnóstico de instalación eléctrica',
  },
  {
    number: '02',
    title: 'Soluciones a medida, no genéricas',
    desc: 'Cada empresa y hogar tiene necesidades distintas. Diseñamos y configuramos cada sistema específicamente para tu proceso, presupuesto y condiciones.',
    img: 'https://images.unsplash.com/photo-1519389950473-47ba0277781c?w=900&auto=format&fit=crop&q=75',
    imgAlt: 'Equipo diseñando solución técnica personalizada',
  },
  {
    number: '03',
    title: 'Soporte post-instalación continuo',
    desc: 'Nuestro compromiso no termina al entregar el proyecto. Ofrecemos soporte técnico por teléfono, WhatsApp y visita para resolver cualquier duda o ajuste.',
    img: 'https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=900&auto=format&fit=crop&q=75',
    imgAlt: 'Técnico brindando soporte técnico post-instalación',
  },
];
---

<section id="diferenciadores" class="py-24 lg:py-32 bg-surface-800" aria-labelledby="diferenciadores-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <header class="text-center max-w-2xl mx-auto mb-20">
      <p class="font-sub text-blue-400 text-sm tracking-widest mb-3">NUESTRA PROMESA</p>
      <h2 id="diferenciadores-heading" class="font-heading text-5xl sm:text-6xl text-white mb-4">
        CÓMO NOS DISTINGUIMOS
      </h2>
      <p class="text-slate-400 text-lg leading-relaxed">
        Tres pilares que definen cada proyecto que realizamos y que nuestros clientes han validado durante más de tres décadas.
      </p>
    </header>

    <!-- Differentiator items (alternating layout) -->
    <div class="space-y-20">
      {differentiators.map((d, i) => (
        <div class={`flex flex-col ${i % 2 === 1 ? 'lg:flex-row-reverse' : 'lg:flex-row'} gap-10 lg:gap-16 items-center`}>

          <!-- Image side -->
          <div class="w-full lg:w-1/2 relative">
            <div class="relative rounded-2xl overflow-hidden shadow-2xl">
              <img
                src={d.img}
                alt={d.imgAlt}
                width="900"
                height="600"
                loading="lazy"
                decoding="async"
                class="w-full h-72 lg:h-96 object-cover"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-surface-900/60 to-transparent"></div>
            </div>
            <!-- Large number decoration -->
            <div
              class="absolute -top-6 -left-4 font-heading text-8xl lg:text-9xl text-blue-900/30 select-none pointer-events-none leading-none"
              aria-hidden="true"
            >
              {d.number}
            </div>
          </div>

          <!-- Text side -->
          <div class="w-full lg:w-1/2">
            <span class="font-sub text-blue-400 text-sm tracking-widest mb-2 block">DIFERENCIADOR {d.number}</span>
            <h3 class="font-heading text-4xl sm:text-5xl text-white mb-4">{d.title}</h3>
            <p class="text-slate-400 text-lg leading-relaxed">{d.desc}</p>

            <!-- Divider line -->
            <div class="mt-8 flex items-center gap-3">
              <div class="h-px flex-1 bg-white/10"></div>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-blue-600 flex-shrink-0" aria-hidden="true">
                <path fill-rule="evenodd" d="M14.615 1.595a.75.75 0 01.359.852L12.982 9.75h7.268a.75.75 0 01.548 1.262l-10.5 11.25a.75.75 0 01-1.272-.71l1.992-7.302H3.818a.75.75 0 01-.548-1.262l10.5-11.25a.75.75 0 01.845-.143z" clip-rule="evenodd"/>
              </svg>
              <div class="h-px flex-1 bg-white/10"></div>
            </div>
          </div>

        </div>
      ))}
    </div>

    <!-- Mid-section CTA band -->
    <div class="mt-24 relative rounded-3xl overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-r from-blue-900/80 to-cyan-900/60"></div>
      <div class="absolute inset-0">
        <img
          src="https://images.unsplash.com/photo-1509391366360-2e959784a276?w=1200&auto=format&fit=crop&q=70"
          alt=""
          width="1200"
          height="400"
          loading="lazy"
          decoding="async"
          class="w-full h-full object-cover opacity-20"
          aria-hidden="true"
        />
      </div>
      <div class="relative z-10 flex flex-col sm:flex-row items-center justify-between gap-6 px-8 py-10 lg:px-14 lg:py-14">
        <div>
          <p class="font-sub text-blue-300 text-sm tracking-widest mb-1">PRIMERA CONSULTA SIN COSTO</p>
          <h3 class="font-heading text-3xl sm:text-4xl text-white">¿TIENES UN PROYECTO EN MENTE?</h3>
          <p class="text-slate-300 mt-2 max-w-lg">Cuéntanos tu necesidad y te preparamos una propuesta técnica y económica sin compromiso.</p>
        </div>
        <!-- TODO: swap number -->
        <a
          href="https://wa.me/+526692629862?text=Hola%2C%20me%20gustar%C3%ADa%20agendar%20un%20diagn%C3%B3stico%20sin%20costo%20para%20mi%20proyecto."
          target="_blank"
          rel="noopener noreferrer"
          class="flex-shrink-0 inline-flex items-center gap-3 px-7 py-4 rounded-xl text-base font-bold text-white bg-green-600 hover:bg-green-500 transition-all duration-200 shadow-lg hover:shadow-green-600/40 hover:scale-[1.02] focus-visible:ring-2 focus-visible:ring-green-400"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 flex-shrink-0" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Agendar diagnóstico gratis
        </a>
      </div>
    </div>

  </div>
</section>
