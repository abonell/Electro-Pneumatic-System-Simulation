---
import Logo from './Logo.astro';
import { waUrl, url } from '../data/site';

const WA_HREF = waUrl();

const navLinks = [
  { label: 'Inicio',      href: url('/') },
  { label: 'Servicios',   href: url('/servicios') },
  { label: 'Proyectos',   href: url('/proyectos') },
  { label: 'Cotización',  href: url('/cotizacion') },
  { label: 'Contacto',    href: url('/contacto') },
];
---

<header
  id="site-header"
  class="fixed top-0 inset-x-0 z-40 transition-all duration-300"
  aria-label="Encabezado del sitio"
>
  <!-- Backdrop: only visible after scroll — JS toggles -->
  <div
    id="nav-backdrop"
    class="absolute inset-0 border-b border-transparent transition-all duration-300"
    aria-hidden="true"
  ></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <nav
      class="flex items-center justify-between h-16 sm:h-18"
      role="navigation"
      aria-label="Navegación principal"
    >
      <!-- Logo / brand — uses Logo.astro wordmark -->
      <a
        href={url('/')}
        class="flex items-center focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-400 rounded-lg p-1 group"
        aria-label="Electroneumática Interactiva — inicio"
      >
        <Logo wordmark size={36} />
      </a>

      <!-- Desktop nav links -->
      <ul class="hidden lg:flex items-center gap-1 list-none p-0 m-0" role="list">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class="nav-link px-3 py-2 rounded-lg text-sm font-medium text-slate-300 hover:text-white hover:bg-white/5 transition-all duration-200 relative after:absolute after:bottom-0 after:left-3 after:right-3 after:h-0.5 after:bg-blue-500 after:scale-x-0 after:transition-transform after:duration-200 hover:after:scale-x-100"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Desktop CTA + theme toggle + mobile toggle -->
      <div class="flex items-center gap-3">
        <!-- WhatsApp CTA button (desktop) -->
        <a
          href={WA_HREF}
          target="_blank"
          rel="noopener noreferrer"
          class="hidden sm:inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-semibold bg-green-600 hover:bg-green-500 text-white transition-all duration-200 hover:shadow-lg hover:shadow-green-600/30 hover:scale-[1.03] focus-visible:ring-2 focus-visible:ring-green-400"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 flex-shrink-0" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp
        </a>

        <!-- Theme toggle (sun = shown on dark → click to go light; moon = shown on light → click to go dark) -->
        <button
          id="theme-toggle"
          type="button"
          aria-label="Activar modo claro"
          title="Cambiar tema"
        >
          <!-- Moon icon — shown in dark mode (click to switch to light) -->
          <svg class="icon-moon w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M9.528 1.718a.75.75 0 01.162.819A8.97 8.97 0 009 6a9 9 0 009 9 8.97 8.97 0 003.463-.69.75.75 0 01.981.98 10.503 10.503 0 01-9.694 6.46c-5.799 0-10.5-4.701-10.5-10.5 0-4.368 2.667-8.112 6.46-9.694a.75.75 0 01.818.162z" clip-rule="evenodd"/>
          </svg>
          <!-- Sun icon — shown in light mode (click to switch to dark) -->
          <svg class="icon-sun w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2.25a.75.75 0 01.75.75v2.25a.75.75 0 01-1.5 0V3a.75.75 0 01.75-.75zM7.5 12a4.5 4.5 0 119 0 4.5 4.5 0 01-9 0zM18.894 6.166a.75.75 0 00-1.06-1.06l-1.591 1.59a.75.75 0 101.06 1.061l1.591-1.59zM21.75 12a.75.75 0 01-.75.75h-2.25a.75.75 0 010-1.5H21a.75.75 0 01.75.75zM17.834 18.894a.75.75 0 001.06-1.06l-1.59-1.591a.75.75 0 10-1.061 1.06l1.59 1.591zM12 18a.75.75 0 01.75.75V21a.75.75 0 01-1.5 0v-2.25A.75.75 0 0112 18zM7.166 17.834a.75.75 0 00-1.06 1.06l1.59 1.591a.75.75 0 001.061-1.06l-1.59-1.591zM6 12a.75.75 0 01-.75.75H3a.75.75 0 010-1.5h2.25A.75.75 0 016 12zM6.166 6.166a.75.75 0 001.06 1.06l1.591-1.59a.75.75 0 00-1.061-1.061l-1.59 1.591z"/>
          </svg>
        </button>

        <!-- Mobile hamburger -->
        <button
          id="menu-toggle"
          type="button"
          class="lg:hidden flex flex-col gap-1.5 p-2 rounded-lg hover:bg-white/10 transition-colors duration-200 focus-visible:ring-2 focus-visible:ring-blue-400"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Abrir menú de navegación"
        >
          <span class="hamburger-bar block w-6 h-0.5 bg-white rounded-full transition-all duration-300 origin-center"></span>
          <span class="hamburger-bar block w-6 h-0.5 bg-white rounded-full transition-all duration-300"></span>
          <span class="hamburger-bar block w-6 h-0.5 bg-white rounded-full transition-all duration-300 origin-center"></span>
        </button>
      </div>
    </nav>

    <!-- Mobile menu drawer -->
    <div
      id="mobile-menu"
      class="lg:hidden overflow-hidden max-h-0 transition-all duration-300 ease-in-out"
      aria-hidden="true"
    >
      <div class="pt-2 pb-4 space-y-1 border-t border-white/10 mt-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="mobile-nav-link block px-4 py-3 rounded-lg text-base font-medium text-slate-300 hover:text-white hover:bg-white/5 transition-all duration-200"
          >
            {link.label}
          </a>
        ))}
        <div class="pt-3 px-4">
          <a
            href={WA_HREF}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-2 w-full px-4 py-3 rounded-lg text-sm font-semibold bg-green-600 hover:bg-green-500 text-white transition-colors duration-200"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Contáctenos por WhatsApp
          </a>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  // ── Theme toggle ─────────────────────────────────────────────────────
  const themeBtn = document.getElementById('theme-toggle');

  const applyTheme = (theme: string) => {
    document.documentElement.setAttribute('data-theme', theme);
    localStorage.setItem('theme', theme);
    // Update meta theme-color dynamically for browsers that respect it
    document.querySelectorAll<HTMLMetaElement>('meta[name="theme-color"]').forEach(m => {
      const media = m.getAttribute('media') || '';
      if (media.includes('dark'))  m.content = theme === 'dark'  ? '#050810' : '#f7f9fc';
      if (media.includes('light')) m.content = theme === 'light' ? '#f7f9fc' : '#050810';
    });
    if (themeBtn) {
      themeBtn.setAttribute(
        'aria-label',
        theme === 'dark' ? 'Activar modo claro' : 'Activar modo oscuro'
      );
    }
    // Signal other scripts (e.g. navbar backdrop) to refresh
    document.documentElement.dispatchEvent(new CustomEvent('themechange'));
  };

  themeBtn?.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme') ?? 'dark';
    applyTheme(current === 'dark' ? 'light' : 'dark');
  });

  // Sync aria-label on load
  const initialTheme = document.documentElement.getAttribute('data-theme') ?? 'dark';
  if (themeBtn) {
    themeBtn.setAttribute(
      'aria-label',
      initialTheme === 'dark' ? 'Activar modo claro' : 'Activar modo oscuro'
    );
  }

  // Listen for OS-level changes only when user has no saved preference
  window.matchMedia('(prefers-color-scheme: light)').addEventListener('change', (e) => {
    if (!localStorage.getItem('theme')) {
      applyTheme(e.matches ? 'light' : 'dark');
    }
  });

  // ── Scroll → frosted glass navbar ──────────────────────────────────
  const backdrop = document.getElementById('nav-backdrop');
  const onScroll = () => {
    const scrolled = window.scrollY > 40;
    const isLight  = document.documentElement.getAttribute('data-theme') === 'light';
    if (backdrop) {
      backdrop.style.backgroundColor = scrolled
        ? (isLight ? 'rgba(247,249,252,0.90)' : 'rgba(5,8,16,0.82)')
        : (isLight ? 'rgba(247,249,252,0)'    : 'rgba(5,8,16,0)');
      backdrop.style.backdropFilter  = scrolled ? 'blur(14px) saturate(150%)' : 'blur(0)';
      backdrop.style.webkitBackdropFilter = scrolled ? 'blur(14px) saturate(150%)' : 'blur(0)';
      backdrop.style.borderColor     = scrolled
        ? (isLight ? 'rgba(15,23,42,0.09)' : 'rgba(255,255,255,0.07)')
        : 'transparent';
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  // Re-run on theme change so navbar is correct if user toggles while scrolled
  document.documentElement.addEventListener('themechange', onScroll);
  onScroll();

  // ── Mobile menu toggle ───────────────────────────────────────────────
  const toggle     = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const bars       = toggle?.querySelectorAll<HTMLElement>('.hamburger-bar');

  toggle?.addEventListener('click', () => {
    const open = mobileMenu!.getAttribute('aria-hidden') === 'true';
    mobileMenu!.setAttribute('aria-hidden', open ? 'false' : 'true');
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    mobileMenu!.style.maxHeight = open ? `${mobileMenu!.scrollHeight}px` : '0';

    if (bars && bars.length === 3) {
      if (open) {
        bars[0].style.transform = 'rotate(45deg) translate(4px, 4px)';
        bars[1].style.opacity = '0';
        bars[2].style.transform = 'rotate(-45deg) translate(4px, -4px)';
      } else {
        bars[0].style.transform = '';
        bars[1].style.opacity = '1';
        bars[2].style.transform = '';
      }
    }
  });

  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      if (mobileMenu) {
        mobileMenu.setAttribute('aria-hidden', 'true');
        mobileMenu.style.maxHeight = '0';
        toggle?.setAttribute('aria-expanded', 'false');
        if (bars && bars.length === 3) {
          bars[0].style.transform = '';
          bars[1].style.opacity = '1';
          bars[2].style.transform = '';
        }
      }
    });
  });

  // ── Active nav highlight on scroll ──────────────────────────────────
  const sections = document.querySelectorAll<HTMLElement>('section[id]');
  const navLinks = document.querySelectorAll<HTMLAnchorElement>('.nav-link');

  const navObserver = new IntersectionObserver(
    entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          navLinks.forEach(a => {
            const active = a.getAttribute('href') === `#${id}`;
            a.classList.toggle('text-white', active);
            a.classList.toggle('text-slate-300', !active);
          });
        }
      });
    },
    { rootMargin: '-45% 0px -50% 0px', threshold: 0 }
  );
  sections.forEach(s => navObserver.observe(s));
</script>
