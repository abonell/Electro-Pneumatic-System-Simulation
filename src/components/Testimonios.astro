const colorMap: Record<string, { bg: string; text: string; ring: string; border: string }> = {
  blue:   { bg: 'bg-blue-600',   text: 'text-blue-400',   ring: 'ring-blue-600/30',   border: 'border-blue-700/30' },
  cyan:   { bg: 'bg-cyan-600',   text: 'text-cyan-400',   ring: 'ring-cyan-600/30',   border: 'border-cyan-700/30' },
  violet: { bg: 'bg-violet-600', text: 'text-violet-400', ring: 'ring-violet-600/30', border: 'border-violet-700/30' },
  green:  { bg: 'bg-green-600',  text: 'text-green-400',  ring: 'ring-green-600/30',  border: 'border-green-700/30' },
  amber:  { bg: 'bg-amber-600',  text: 'text-amber-400',  ring: 'ring-amber-600/30',  border: 'border-amber-700/30' },
  rose:   { bg: 'bg-rose-600',   text: 'text-rose-400',   ring: 'ring-rose-600/30',   border: 'border-rose-700/30' },
};
---

<section id="testimonios" class="py-24 lg:py-32" aria-labelledby="testimonios-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <header class="text-center max-w-2xl mx-auto mb-16 reveal">
      <p class="font-sub text-sm tracking-widest mb-3 section-eyebrow inline-flex text-blue-400">LO QUE DICEN NUESTROS CLIENTES</p>
      <h2 id="testimonios-heading" class="font-heading text-5xl sm:text-6xl text-white mb-4 mt-2">
        CASOS DE ÉXITO
      </h2>
      <p class="text-slate-400 text-lg leading-relaxed">
        Más de 500 proyectos completados. Estas son algunas de las experiencias que nuestros clientes han compartido con nosotros.
      </p>
    </header>

    <!-- Testimonials grid — bento-style cards with stagger reveal -->
    <ul
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 reveal-stagger"
      role="list"
      aria-label="Testimonios de clientes"
    >
      {testimonios.map(t => {
        const c = colorMap[t.color];
        return (
          <li>
            <article class="bento-card p-7 flex flex-col h-full">
              <!-- Stars -->
              <div class="flex gap-1 mb-4" role="img" aria-label={`Calificación: ${t.rating} de 5 estrellas`}>
                {Array.from({ length: t.rating }).map(() => (
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-amber-400" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd"/>
                  </svg>
                ))}
              </div>

              <!-- Opening quote mark (decorative) -->
              <div class={`font-heading text-5xl leading-none mb-3 ${c.text} opacity-40 select-none`} aria-hidden="true">&ldquo;</div>

              <!-- Quote -->
              <blockquote class="text-slate-300 text-sm leading-relaxed flex-1 mb-6">
                {t.quote}
              </blockquote>

              <!-- Separator -->
              <div class={`h-px w-12 mb-5 ${c.bg.replace('bg-', 'bg-').replace('/15', '/40')} rounded-full`}></div>

              <!-- Author -->
              <footer class="flex items-center gap-3">
                <div
                  class={`flex items-center justify-center w-10 h-10 rounded-full ${c.bg} ring-2 ${c.ring} flex-shrink-0 font-bold text-white text-sm`}
                  aria-hidden="true"
                >
                  {t.avatar}
                </div>
                <div>
                  <p class="font-semibold text-white text-sm">{t.name}</p>
                  <p class="text-slate-500 text-xs">{t.role}</p>
                  <p class={`font-sub text-xs tracking-wide mt-0.5 ${c.text}`}>{t.company}</p>
                </div>
              </footer>
            </article>
          </li>
        );
      })}
    </ul>

  </div>
</section>
