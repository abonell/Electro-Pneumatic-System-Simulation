---
const benefits = [
  {
    icon: `<path fill-rule="evenodd" d="M8.603 3.799A4.49 4.49 0 0112 2.25c1.357 0 2.573.6 3.397 1.549a4.49 4.49 0 013.498 1.307 4.491 4.491 0 011.307 3.497A4.49 4.49 0 0121.75 12a4.49 4.49 0 01-1.549 3.397 4.491 4.491 0 01-1.307 3.497 4.491 4.491 0 01-3.497 1.307A4.49 4.49 0 0112 21.75a4.49 4.49 0 01-3.397-1.549 4.49 4.49 0 01-3.498-1.306 4.491 4.491 0 01-1.307-3.498A4.49 4.49 0 012.25 12c0-1.357.6-2.573 1.549-3.397a4.49 4.49 0 011.307-3.497 4.49 4.49 0 013.497-1.307zm7.007 6.387a.75.75 0 10-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 00-1.06 1.06l2.25 2.25a.75.75 0 001.14-.094l3.75-5.25z" clip-rule="evenodd"/>`,
    title: '34 Años de Trayectoria',
    desc:  'Décadas resolviendo los retos más complejos de automatización industrial dan como resultado diagnósticos más rápidos y soluciones más durables.',
    color: 'blue',
  },
  {
    icon: `<path d="M12 1.5a.75.75 0 01.75.75V7.5h-1.5V2.25A.75.75 0 0112 1.5zM11.25 7.5v5.69l-1.72-1.72a.75.75 0 00-1.06 1.06l3 3a.75.75 0 001.06 0l3-3a.75.75 0 10-1.06-1.06l-1.72 1.72V7.5h-1.5z"/><path d="M3 15.75a.75.75 0 01.75-.75H6v-1.5H3.75A2.25 2.25 0 001.5 15.75v3A2.25 2.25 0 003.75 21h16.5A2.25 2.25 0 0022.5 18.75v-3a2.25 2.25 0 00-2.25-2.25H18v1.5h2.25a.75.75 0 01.75.75v3a.75.75 0 01-.75.75H3.75a.75.75 0 01-.75-.75v-3z"/>`,
    title: 'Respuesta en 24 Horas',
    desc:  'Ante una falla crítica, cada hora de paro cuesta dinero. Nuestro equipo técnico está disponible para atender emergencias industriales con rapidez y eficiencia.',
    color: 'cyan',
  },
  {
    icon: `<path fill-rule="evenodd" d="M12 6.75a5.25 5.25 0 016.775-5.025.75.75 0 01.313 1.248l-3.32 3.319c.063.475.276.934.641 1.299.365.365.824.578 1.3.641l3.318-3.319a.75.75 0 011.248.313 5.25 5.25 0 01-5.472 6.756c-1.018-.086-1.87.1-2.309.634L7.344 21.3A3.298 3.298 0 112.7 16.657l8.684-7.151c.533-.44.72-1.291.634-2.309A5.342 5.342 0 0112 6.75zM4.117 19.125a.75.75 0 01.75-.75h.008a.75.75 0 01.75.75v.008a.75.75 0 01-.75.75h-.008a.75.75 0 01-.75-.75v-.008z" clip-rule="evenodd"/>`,
    title: 'Técnicos Certificados',
    desc:  'Personal calificado con certificaciones vigentes en automatización, instalaciones eléctricas y sistemas de control. Capacitación continua garantizada.',
    color: 'violet',
  },
  {
    icon: `<path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12zm13.36-1.814a.75.75 0 10-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 00-1.06 1.06l2.25 2.25a.75.75 0 001.14-.094l3.75-5.25z" clip-rule="evenodd"/>`,
    title: 'Garantía en Todo Trabajo',
    desc:  'Cada instalación y reparación incluye garantía escrita. Si algo no funciona como prometimos, regresamos sin costo adicional hasta dejarlo correcto.',
    color: 'green',
  },
  {
    icon: `<path d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5M6 7.5h3v3H6v-3z"/>`,
    title: 'Propuestas Transparentes',
    desc:  'Diagnóstico inicial sin compromiso. Presupuesto detallado con desglose de materiales y mano de obra. Sin letra pequeña ni costos sorpresa.',
    color: 'amber',
  },
  {
    icon: `<path d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25zM4.575 15.6A8.25 8.25 0 0012 20.25a8.25 8.25 0 007.425-4.65 24.562 24.562 0 00-7.425-1.125 24.562 24.562 0 00-7.425 1.125zM12 3.75a8.25 8.25 0 018.25 8.25c0 .899-.142 1.765-.405 2.579a25.946 25.946 0 00-7.845-1.329 25.946 25.946 0 00-7.845 1.33A8.217 8.217 0 013.75 12 8.25 8.25 0 0112 3.75z" clip-rule="evenodd"/>`,
