---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CotizacionForm from '../components/CotizacionForm.astro';
import { SITE, waUrl, url } from '../data/site';

// Optional preselected service from query string
const slug = Astro.url.searchParams.get('servicio') ?? undefined;
---

<Layout
  title="Solicitar cotización | Electroneumática Interactiva"
  description="Solicita una cotización para tu proyecto de electroneumática, domótica o instalaciones eléctricas. Diagnóstico inicial sin costo. Respuesta en menos de 24 h hábiles."
>
  <Header />
  <main id="contenido-principal">

    <section class="pt-32 pb-12 lg:pt-40 lg:pb-16" aria-label="Encabezado de cotización">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <nav aria-label="Migas de pan" class="mb-4 text-sm">
          <ol class="flex items-center gap-2 text-slate-500">
            <li><a href={url('/')} class="hover:text-blue-300 transition-colors">Inicio</a></li>
            <li aria-hidden="true">/</li>
            <li class="text-blue-300">Cotización</li>
          </ol>
        </nav>
        <h1 class="font-heading text-5xl sm:text-6xl lg:text-7xl text-white mb-4">
          SOLICITAR<br/>
          <span class="text-blue-400">COTIZACIÓN</span>
        </h1>
        <p class="text-slate-400 text-lg max-w-2xl">
          Tres formas de empezar: este formulario para casos detallados, WhatsApp para respuesta inmediata,
          o llamada telefónica directa.
        </p>
      </div>
    </section>

    <hr class="section-divider" />

    <!-- Quick contact options -->
    <section class="py-16 bg-surface-800" aria-label="Opciones de contacto rápido">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid sm:grid-cols-3 gap-5 reveal-stagger">

          <a
            href={waUrl('Hola, me interesa solicitar una cotización para mi proyecto.')}
            target="_blank"
            rel="noopener noreferrer"
            class="bento-card p-6 group hover:border-green-500/50 transition-colors"
          >
            <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-green-600/20 border border-green-600/30 mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-green-400" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <h2 class="font-heading text-2xl text-white mb-2">WhatsApp</h2>
            <p class="text-slate-400 text-sm leading-relaxed mb-3">Respuesta inmediata en horario laboral. Recomendado para urgencias y consultas técnicas.</p>
            <span class="text-green-400 text-sm font-semibold inline-flex items-center gap-1.5">
              Iniciar chat
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" aria-hidden="true">
                <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/>
              </svg>
            </span>
          </a>

          <a
            href={`tel:${SITE.phones[0]?.e164}`}
            class="bento-card p-6 group hover:border-blue-500/50 transition-colors"
          >
            <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-blue-600/20 border border-blue-600/30 mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-blue-400" aria-hidden="true">
                <path fill-rule="evenodd" d="M1.5 4.5a3 3 0 013-3h1.372c.86 0 1.61.586 1.819 1.42l1.105 4.423a1.875 1.875 0 01-.694 1.955l-1.293.97c-.135.101-.164.249-.126.352a11.285 11.285 0 006.697 6.697c.103.038.25.009.352-.126l.97-1.293a1.875 1.875 0 011.955-.694l4.423 1.105c.834.209 1.42.959 1.42 1.82V19.5a3 3 0 01-3 3h-2.25C8.552 22.5 1.5 15.448 1.5 6.75V4.5z" clip-rule="evenodd"/>
              </svg>
            </div>
            <h2 class="font-heading text-2xl text-white mb-2">Teléfono</h2>
            <p class="text-slate-400 text-sm leading-relaxed mb-3">Llámanos directamente. Lunes a viernes 8:00–18:00 h, sábado 9:00–14:00 h.</p>
            <span class="text-blue-400 text-sm font-semibold">{SITE.phones[0]?.display}</span>
          </a>

          <a
            href={`mailto:${SITE.emails[0]?.address}`}
            class="bento-card p-6 group hover:border-cyan-500/50 transition-colors"
          >
            <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-cyan-600/20 border border-cyan-600/30 mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-cyan-400" aria-hidden="true">
                <path d="M1.5 8.67v8.58a3 3 0 003 3h15a3 3 0 003-3V8.67l-8.928 5.493a3 3 0 01-3.144 0L1.5 8.67z"/>
                <path d="M22.5 6.908V6.75a3 3 0 00-3-3h-15a3 3 0 00-3 3v.158l9.714 5.978a1.5 1.5 0 001.572 0L22.5 6.908z"/>
              </svg>
            </div>
            <h2 class="font-heading text-2xl text-white mb-2">Correo</h2>
            <p class="text-slate-400 text-sm leading-relaxed mb-3">Para casos detallados con planos o documentación adjunta.</p>
            <span class="text-cyan-400 text-sm font-semibold break-all">{SITE.emails[0]?.address}</span>
          </a>
        </div>
      </div>
    </section>

    <CotizacionForm preselectedServicio={slug} />
  </main>
  <Footer />
</Layout>
