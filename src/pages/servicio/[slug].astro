---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Proceso from '../../components/Proceso.astro';
import { servicios, type Servicio } from '../../data/servicios';
import { proyectos } from '../../data/proyectos';
import { waUrl, url } from '../../data/site';

export async function getStaticPaths() {
  return servicios.map(s => ({
    params: { slug: s.slug },
    props:  { servicio: s },
  }));
}

interface Props {
  servicio: Servicio;
}

const { servicio } = Astro.props;

// Related projects that use this service
const relacionados = proyectos.filter(p => p.servicios.includes(servicio.slug)).slice(0, 3);
---

<Layout
  title={`${servicio.titulo} | Electroneumática Interactiva`}
  description={servicio.descripcionCorta}
>
  <Header />
  <main id="contenido-principal">

    <!-- Hero with image -->
    <section class="relative pt-32 pb-16 lg:pt-40 lg:pb-24 overflow-hidden" aria-label={`Servicio: ${servicio.titulo}`}>
      <div class="absolute inset-0 z-0">
        <img
          src={servicio.imagen}
          alt=""
          aria-hidden="true"
          class="w-full h-full object-cover opacity-20 img-blur-up"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-surface-900 via-surface-900/85 to-surface-900"></div>
      </div>

      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <nav aria-label="Migas de pan" class="mb-6 text-sm">
          <ol class="flex flex-wrap items-center gap-2 text-slate-500">
            <li><a href={url('/')} class="hover:text-blue-300 transition-colors">Inicio</a></li>
            <li aria-hidden="true">/</li>
            <li><a href={url('/servicios')} class="hover:text-blue-300 transition-colors">Servicios</a></li>
            <li aria-hidden="true">/</li>
            <li class="text-blue-300">{servicio.titulo}</li>
          </ol>
        </nav>

        <div class="max-w-3xl">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-xl bg-blue-600/20 border border-blue-600/30 mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7 text-blue-400" aria-hidden="true">
              <path d={servicio.iconPath}/>
            </svg>
          </div>

          <h1 class="font-heading text-5xl sm:text-6xl lg:text-7xl text-white mb-6">
            {servicio.titulo.toUpperCase()}
          </h1>
          <p class="text-slate-300 text-lg leading-relaxed mb-8">{servicio.descripcionLarga}</p>

          <ul class="flex flex-wrap gap-2 mb-8" aria-label="Tags del servicio">
            {servicio.tags.map(tag => (
              <li class="px-3 py-1 rounded-full text-xs font-medium bg-blue-900/40 text-blue-300 border border-blue-700/30">
                {tag}
              </li>
            ))}
          </ul>

          <div class="flex flex-col sm:flex-row gap-3">
            <a
              href={`${url('/cotizacion')}?servicio=${servicio.slug}`}
              class="btn-magnetic inline-flex items-center justify-center gap-3 px-7 py-4 rounded-xl text-base font-bold text-white bg-blue-600 hover:bg-blue-500 transition-all duration-200 shadow-lg hover:shadow-blue-600/30 hover:scale-[1.03] focus-visible:ring-2 focus-visible:ring-blue-400"
            >
              Solicitar cotización
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4" aria-hidden="true">
                <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/>
              </svg>
            </a>
            <a
              href={waUrl(`Hola, me interesa el servicio de ${servicio.titulo}. ¿Pueden enviarme más información?`)}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-3 px-7 py-4 rounded-xl text-base font-semibold text-white bg-green-600 hover:bg-green-500 transition-all duration-200 shadow-lg hover:shadow-green-600/30 focus-visible:ring-2 focus-visible:ring-green-400"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              WhatsApp directo
            </a>
          </div>
        </div>
      </div>
    </section>

    <hr class="section-divider" />

    <!-- Beneficios + Alcance -->
    <section class="py-20 lg:py-28 bg-surface-800" aria-label="Beneficios y alcance">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-10 lg:gap-16">

          <!-- Beneficios -->
          <article class="reveal">
            <p class="font-sub text-sm tracking-widest text-blue-400 mb-3 section-eyebrow inline-flex">BENEFICIOS</p>
            <h2 class="font-heading text-4xl sm:text-5xl text-white mb-6">QUÉ GANAS</h2>
            <ul class="space-y-3" role="list">
              {servicio.beneficios.map(b => (
                <li class="flex items-start gap-3 text-slate-300">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-green-400 flex-shrink-0 mt-1" aria-hidden="true">
                    <path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12zm13.36-1.814a.75.75 0 10-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 00-1.06 1.06l2.25 2.25a.75.75 0 001.14-.094l3.75-5.25z" clip-rule="evenodd"/>
                  </svg>
                  <span class="leading-relaxed">{b}</span>
                </li>
              ))}
            </ul>
          </article>

          <!-- Alcance -->
          <article class="reveal">
            <p class="font-sub text-sm tracking-widest text-blue-400 mb-3 section-eyebrow inline-flex">QUÉ INCLUYE</p>
            <h2 class="font-heading text-4xl sm:text-5xl text-white mb-6">ALCANCE DEL SERVICIO</h2>
            <ul class="space-y-3" role="list">
              {servicio.alcance.map((item, i) => (
                <li class="flex items-start gap-3 text-slate-300">
                  <span class="flex-shrink-0 flex items-center justify-center w-6 h-6 rounded-md bg-blue-600/20 border border-blue-600/30 text-xs font-bold text-blue-300 mt-0.5">
                    {(i + 1).toString().padStart(2, '0')}
                  </span>
                  <span class="leading-relaxed">{item}</span>
                </li>
              ))}
            </ul>
          </article>

        </div>
      </div>
    </section>

    <hr class="section-divider" />
    <Proceso />

    {relacionados.length > 0 && (
      <>
        <hr class="section-divider" />
        <section class="py-20 lg:py-28 bg-surface-800" aria-label="Proyectos relacionados">
          <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <header class="text-center max-w-2xl mx-auto mb-12 reveal">
              <p class="font-sub text-sm tracking-widest text-blue-400 mb-3 section-eyebrow inline-flex">CASOS RELACIONADOS</p>
              <h2 class="font-heading text-4xl sm:text-5xl text-white mb-3 mt-2">PROYECTOS REALIZADOS</h2>
              <p class="text-slate-400 leading-relaxed">
                Casos de éxito donde aplicamos {servicio.titulo.toLowerCase()} para resolver retos reales.
              </p>
            </header>

            <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 reveal-stagger" role="list">
              {relacionados.map(p => (
                <li>
                  <a
                    href={url(`/proyecto/${p.slug}`)}
                    class="bento-card group flex flex-col overflow-hidden h-full focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-400"
                  >
                    <div class="relative h-44 overflow-hidden">
                      <img
                        src={p.imagen}
                        alt={p.imagenAlt}
                        loading="lazy"
                        decoding="async"
                        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.04] img-blur-up"
                      />
                    </div>
                    <div class="flex flex-col flex-1 p-5">
                      <p class="font-sub text-xs tracking-widest text-cyan-400 mb-1.5">{p.cliente}</p>
                      <h3 class="font-heading text-xl text-white mb-2 group-hover:text-blue-300 transition-colors">
                        {p.titulo}
                      </h3>
                      <p class="text-slate-400 text-sm leading-relaxed flex-1">{p.resumen}</p>
                    </div>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </section>
      </>
    )}

    <!-- CTA final -->
    <section class="py-20" aria-label="CTA final">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
        <h2 class="font-heading text-4xl sm:text-5xl text-white mb-4">
          ¿NECESITAS {servicio.titulo.toUpperCase()}?
        </h2>
        <p class="text-slate-400 text-lg mb-8 max-w-xl mx-auto">
          Diagnóstico inicial sin costo. Cotización detallada en 5 días hábiles.
        </p>
        <a
          href={`${url('/cotizacion')}?servicio=${servicio.slug}`}
          class="btn-magnetic inline-flex items-center gap-3 px-8 py-4 rounded-xl text-base font-bold text-white bg-blue-600 hover:bg-blue-500 transition-all duration-200 shadow-lg hover:shadow-blue-600/30 hover:scale-[1.03] focus-visible:ring-2 focus-visible:ring-blue-400"
        >
          Solicitar cotización
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4" aria-hidden="true">
            <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/>
          </svg>
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
